# Copie este arquivo para .env e preencha sua chave
OPENAI_API_KEY=

# Engine de STT (reconhecimento de fala): 'google' ou 'openai'
STT_ENGINE=google

# Configurações do microfone (opcionais)
# Índice do dispositivo de microfone (use None para padrão)
MIC_DEVICE_INDEX=
# Taxa de amostragem (ex.: 16000, 44100). Vazio para padrão
MIC_SAMPLE_RATE=
# Tamanho do chunk para leitura do microfone
MIC_CHUNK_SIZE=1024

# Ajustes de captação e reconhecimento
LISTEN_TIMEOUT=10
PHRASE_TIME_LIMIT=6
AMBIENT_DURATION=0.6
QA_TIMEOUT=15
QA_PHRASE_TIME_LIMIT=12
RECOGNITION_RETRIES=1

# Parâmetros do recognizer
DYNAMIC_ENERGY=true
# ENERGY_THRESHOLD vazio mantém o padrão e permite ajuste dinâmico
ENERGY_THRESHOLD=
PAUSE_THRESHOLD=0.8
NON_SPEAKING_DURATION=0.5
